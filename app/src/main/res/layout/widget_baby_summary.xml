<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="11dp"
    android:paddingEnd="12dp"
    android:paddingBottom="9dp">

    <TextView
        android:id="@+id/widget_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_text_pill"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:maxWidth="205dp"
        android:minWidth="112dp"
        android:text="Малюк"
        android:textColor="#F7F7FA"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_text_pill"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:maxWidth="200dp"
        android:minWidth="92dp"
        android:text="Сон"
        android:textColor="#EEF0F5"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/widget_stat_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_text_pill"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:maxWidth="100dp"
            android:minWidth="72dp"
            android:text="0 год"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_stat_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:background="@drawable/widget_text_pill"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:maxWidth="100dp"
            android:minWidth="72dp"
            android:text="0 хв"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_recent_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_text_pill"
        android:gravity="center"
        android:maxWidth="200dp"
        android:minWidth="112dp"
        android:text="Загальна"
        android:textColor="#F7F7FA"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_recent_first"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:background="@drawable/widget_text_pill"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:maxWidth="205dp"
        android:minWidth="72dp"
        android:text="Записів ще немає"
        android:textColor="#ECEEF4"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_recent_second"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:background="@drawable/widget_text_pill"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:maxWidth="205dp"
        android:minWidth="72dp"
        android:text=""
        android:textColor="#D7DAE2"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="5dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_arrow_button"
            android:contentDescription="Назад"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/widget_chevron_left" />

        <ImageButton
            android:id="@+id/widget_open_app"
            android:layout_width="62dp"
            android:layout_height="28dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_open_button"
            android:contentDescription="Відкрити додаток"
            android:padding="0dp" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/widget_arrow_button"
            android:contentDescription="Далі"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/widget_chevron_right" />
    </LinearLayout>
</LinearLayout>




